{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "name": "peec-mom-unified-framework",
  "version": "1.0.0",
  "description": "Commercial-grade PEEC-MoM electromagnetic simulation framework",
  "homepage": "https://github.com/your-org/peec-mom-framework",
  "license": "MIT",
  "dependencies": [
    {
      "name": "boost-geometry",
      "version>=": "1.89.0"
    },
    {
      "name": "openblas",
      "version>=": "0.3.30"
    },
    {
      "name": "cgal",
      "version>=": "6.1.0",
      "features": ["core", "mesh-2", "mesh-3", "surface-mesh"]
    },
    {
      "name": "eigen3",
      "version>=": "3.4.0"
    },
    {
      "name": "gmsh",
      "version>=": "4.15.0"
    },
    {
      "name": "opencascade",
      "version>=": "7.8.0"
    },
    {
      "name": "clipper2",
      "version>=": "1.5.0"
    },
    {
      "name": "triangle",
      "version>=": "1.6.0"
    },
    {
      "name": "openmp",
      "platform": "windows"
    },
    {
      "name": "cuda",
      "version>=": "12.0",
      "platform": "windows & x64"
    },
    {
      "name": "opencl",
      "version>=": "3.0"
    },
    {
      "name": "petsc",
      "version>=": "3.24.0"
    }
  ],
  "builtin-baseline": "2024.01.12"
}

